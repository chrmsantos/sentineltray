# =============================================================================
# SentinelTray - runtime data (NEVER commit these)
# =============================================================================

# User config (contains email addresses, SMTP settings)
config/config.local.yaml
config/config.local.yaml.edit

# Allow the committed example/template file
!config/config.local.yaml.example

# Encrypted config and the symmetric key that unlocks it
config/config.local.key
config/config.local.yaml.enc

# DPAPI-encrypted SMTP passwords
config/smtp_password_*.dpapi

# Runtime state and PID file
config/state.json
config/sentineltray.pid

# Logs, telemetry, email queue, and error snapshots
config/logs/

# =============================================================================
# Legacy paths
# =============================================================================
state.json
logs/*.log
logs/telemetry.json
config.local.yaml.edit
config.local.yaml
config.local.key
*.local.yaml
tmp/

